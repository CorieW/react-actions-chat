{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": ["docs-chat/frontend/homepageChatDemo.ts"],
      "project": [
        "config/**/*.{js,ts}",
        "docs-chat/frontend/**/*.{ts,tsx}",
        "scripts/**/*.{js,ts}",
        "src/**/*.{js,jsx,ts,tsx}"
      ],
      "ignore": ["config/tailwind.config.js", "scripts/build-styles-simple.js"],
      "ignoreDependencies": [
        "agentsmd-hierarchy",
        "prettier-plugin-tailwindcss",
        "tailwindcss"
      ]
    },
    "docs-chat/backend": {
      "project": ["**/*.{js,ts}"],
      "ignoreDependencies": ["@google-cloud/functions-framework"]
    },
    "packages/react-actions-chat-llms": {
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/react-actions-chat-recommended-actions": {
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/react-actions-chat-support": {
      "project": ["src/**/*.{ts,tsx}"]
    },
    "examples/qa-bot": {
      "project": ["**/*.{ts,tsx}"]
    },
    "examples/coding": {
      "project": ["**/*.{ts,tsx}"]
    },
    "examples/llm-support": {
      "project": ["**/*.{ts,tsx}"]
    },
    "examples/login": {
      "project": ["**/*.{ts,tsx}"]
    },
    "examples/settings": {
      "project": ["**/*.{ts,tsx}"]
    },
    "examples/support-desk": {
      "project": ["**/*.{ts,tsx}"]
    },
    "examples/uploads": {
      "project": ["**/*.{ts,tsx}"]
    }
  }
}
