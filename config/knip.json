{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "project": [
        "config/**/*.{js,ts}",
        "scripts/**/*.{js,ts}",
        "src/**/*.{js,jsx,ts,tsx}"
      ],
      "ignore": ["config/tailwind.config.js", "scripts/build-styles-simple.js"],
      "ignoreDependencies": ["prettier-plugin-tailwindcss"]
    },
    "packages/react-actions-chat-recommended-actions": {
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/react-actions-chat-support": {
      "project": ["src/**/*.{ts,tsx}"]
    },
    "examples/qa-bot": {
      "project": ["**/*.{ts,tsx}"]
    },
    "examples/coding": {
      "project": ["**/*.{ts,tsx}"]
    },
    "examples/login": {
      "project": ["**/*.{ts,tsx}"]
    },
    "examples/settings": {
      "project": ["**/*.{ts,tsx}"]
    }
  }
}
