{
  "name": "actionable-support-chat-recommended-actions",
  "version": "0.0.0",
  "license": "Unlicense",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./embedders": "./src/embedders/index.ts"
  },
  "scripts": {
    "build": "tsc --noEmit -p ../../config/tsconfig.json",
    "build:watch": "tsc --watch -p ../../config/tsconfig.json",
    "lint": "eslint . --config ../../config/eslint.config.js",
    "format": "prettier --write . --config ../../config/.prettierrc --ignore-path ../../.gitignore --ignore-path ../../config/.prettierignore",
    "format:check": "prettier --check . --config ../../config/.prettierrc --ignore-path ../../.gitignore --ignore-path ../../config/.prettierignore",
    "test": "vitest --config ../../config/vite.config.ts",
    "typecheck": "tsc --noEmit -p ../../config/tsconfig.json",
    "test:coverage": "vitest --coverage --config ../../config/vite.config.ts"
  },
  "peerDependencies": {
    "actionable-support-chat": "*"
  },
  "devDependencies": {
    "actionable-support-chat": "workspace:*"
  }
}
