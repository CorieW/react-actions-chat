{
  "name": "react-actions-chat-llms",
  "version": "1.0.1",
  "description": "Backend-routed text-generation helpers for react-actions-chat flows.",
  "keywords": [
    "react",
    "chat",
    "llm",
    "ai",
    "text-generation",
    "assistant",
    "react-actions-chat"
  ],
  "author": "CorieW",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CorieW/react-actions-chat.git",
    "directory": "packages/react-actions-chat-llms"
  },
  "homepage": "https://github.com/CorieW/react-actions-chat/tree/main/packages/react-actions-chat-llms#readme",
  "bugs": {
    "url": "https://github.com/CorieW/react-actions-chat/issues"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "sideEffects": false,
  "files": [
    "src/index.ts",
    "src/chatTextGenerationFlow.ts",
    "src/shared.ts",
    "src/textGenerationBackend.ts",
    "README.md"
  ],
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc --noEmit -p ../../config/tsconfig.json",
    "build:watch": "tsc --watch -p ../../config/tsconfig.json",
    "lint": "eslint . --config ../../config/eslint.config.js",
    "format": "prettier --write . --config ../../config/.prettierrc --ignore-path ../../.gitignore --ignore-path ../../config/.prettierignore",
    "format:check": "prettier --check . --config ../../config/.prettierrc --ignore-path ../../.gitignore --ignore-path ../../config/.prettierignore",
    "test": "vitest --config ../../config/vite.config.ts",
    "typecheck": "tsc --noEmit -p ../../config/tsconfig.json",
    "test:coverage": "vitest --coverage --config ../../config/vite.config.ts"
  },
  "peerDependencies": {
    "react-actions-chat": "*"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "react-actions-chat": "workspace:*"
  }
}
