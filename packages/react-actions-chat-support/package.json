{
  "name": "react-actions-chat-support",
  "version": "1.0.1",
  "description": "Support-desk flow helpers and in-memory adapters for react-actions-chat.",
  "keywords": [
    "react",
    "chat",
    "support",
    "support-desk",
    "customer-support",
    "workflow",
    "react-actions-chat"
  ],
  "author": "CorieW",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CorieW/react-actions-chat.git",
    "directory": "packages/react-actions-chat-support"
  },
  "homepage": "https://github.com/CorieW/react-actions-chat/tree/main/packages/react-actions-chat-support#readme",
  "bugs": {
    "url": "https://github.com/CorieW/react-actions-chat/issues"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "sideEffects": false,
  "files": [
    "src/index.ts",
    "src/supportFlowTypes.ts",
    "src/memorySupportFlowAdapter.ts",
    "src/userSupportFlow.ts",
    "src/adminSupportFlow.ts",
    "README.md"
  ],
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc --noEmit -p ../../config/tsconfig.json",
    "build:watch": "tsc --watch -p ../../config/tsconfig.json",
    "lint": "eslint . --config ../../config/eslint.config.js",
    "format": "prettier --write . --config ../../config/.prettierrc --ignore-path ../../.gitignore --ignore-path ../../config/.prettierignore",
    "format:check": "prettier --check . --config ../../config/.prettierrc --ignore-path ../../.gitignore --ignore-path ../../config/.prettierignore",
    "test": "vitest --config ../../config/vite.config.ts",
    "typecheck": "tsc --noEmit -p ../../config/tsconfig.json",
    "test:coverage": "vitest --coverage --config ../../config/vite.config.ts"
  },
  "peerDependencies": {
    "react-actions-chat": "*"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "react-actions-chat": "workspace:*"
  }
}
